# Required: Web search for finding opinions
# Supports multiple keys (comma-separated) for round-robin rotation:
#   EXA_API_KEY=key1,key2,key3
EXA_API_KEY=your-exa-api-key

# Required: Embeddings (primary)
# Supports multiple keys (comma-separated) for round-robin rotation:
#   MISTRAL_API_KEY=key1,key2,key3
MISTRAL_API_KEY=your-mistral-api-key

# Required: Embeddings fallback + LLM synthesis
# Supports multiple keys (comma-separated) for round-robin rotation:
#   OPENROUTER_API_KEY=sk-key1,sk-key2,sk-key3
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Firecrawl for better scraping
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Cerebras API (high-performance LLM inference)
# Supports multiple keys for round-robin rotation
CEREBRAS_API_KEY=your-cerebras-api-key

# Parallel.ai (high-accuracy web search + content extraction for AI agents)
# Supports multiple keys for round-robin rotation
PARALLEL_API_KEY=your-parallel-api-key
